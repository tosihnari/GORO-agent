# ============================================================
# GORO Claude Code 環境変数テンプレート
# このファイルをコピーして .env を作成し、値を埋めてください
# cp .env.example .env
# ============================================================

# --- 共有トークン（1Passwordまたは旭さんから受け取る） ---

# Notion インテグレーショントークン
NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Slack Bot トークン
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxx-xxxxxxxxxx-xxxxxxxxxxxxxxxx

# --- 個人トークン（各自で取得） ---

# Figma パーソナルアクセストークン
# 取得先: Figma → Settings → Account → Personal access tokens
FIGMA_API_KEY=figd_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Figmaファイルキー（作業中のファイルに応じて変更）
FIGMA_FILE_KEY=xxxxxxxxxxxxxxxxxxxxxx

# Google OAuth（Gmail/カレンダー連携）
# 取得方法: 旭さんに確認
GOOGLE_CLIENT_ID=xxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_REFRESH_TOKEN=1//xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
